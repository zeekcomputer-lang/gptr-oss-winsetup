# ════════════════════════════════════════════════════════════════════════
#  GPT-Researcher × GPT-OSS — Windows 올인원 환경설정
#  복사: copy .env.example .env   (Windows)  /  cp .env.example .env
# ════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# 1) LLM (gpt-oss) — OpenAI 호환 엔드포인트
#    deep-doc-pipeline 패턴: base_url + default_headers(인증) + api_key 더미
# ───────────────────────────────────────────────────────────────
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=unused

# 모델 매핑 (gpt_researcher 형식: "<provider>:<model>")
# provider 는 openai 고정(=OpenAI 호환). model 은 서빙 중인 gpt-oss 이름.
FAST_LLM=openai:gpt-oss-20b
SMART_LLM=openai:gpt-oss-120b
STRATEGIC_LLM=openai:gpt-oss-120b

# LLM 기본 헤더 (JSON). SDK(ChatOpenAI)의 default_headers 인자로 전달됨(deepdoc 방식).
#   - LLM 호출에만 주입. 임베딩(BGE)에는 절대 적용 안 됨.
#   - ★ 우선순위(폴백, 병합 아님): 1) 이 .env  2) 코드 _HARDCODED_LLM_HEADERS  3) 둘 다 없으면 헤더 없이 호출.
#     (이 값이 설정되면 하드코딩은 무시됨)
#   - 값에 플레이스홀더 사용 가능(패치가 치환): ${uuid4} / ${uuid4hex} / ${epoch}
#     → 헤더별로 독립 생성. 프로세스 기동 시 1회 고정(=기본 헤더).
#   - 서비스가 요구하는 변수명을 그대로 키로 적는다(정적값·UUID 혼용 가능):
# OPENAI_EXTRA_HEADERS={"x-ticket":"key_123","user_Id":"abcde","extra_keys12":"${uuid4}"}

# 요청당 새 UUID 헤더 (선택): 지정한 이름의 헤더를 매 LLM 호출마다 새 uuid4 로 붙임.
#   - request-id/추적용. default_headers(고정)보다 우선해 매 호출 갱신됨.
#   - 쉼표로 여러 개 지정 가능(헤더별 독립 uuid). 임베딩엔 미적용. 비워두면 비활성.
# OPENAI_DYNAMIC_UUID_HEADER=X-Trace-Id,X-Session-Id

# 토큰 한도 (gpt-oss 출력 길이에 맞게 조정)
FAST_TOKEN_LIMIT=3000
SMART_TOKEN_LIMIT=8000
STRATEGIC_TOKEN_LIMIT=8000
TEMPERATURE=0.4

# ───────────────────────────────────────────────────────────────
# 2) 임베딩 (BGE) — 사용자가 별도로 운영하는 엔드포인트에 접속만 함
#    ※ 이 repo 는 임베딩 서버를 구동하지 않는다. 아래 URL 로 POST 호출만 한다.
#    - provider 는 openai 고정(=OpenAI 호환). model 은 서버가 응답하는 이름.
#    - EMBEDDING_BASE_URL 은 서버의 /v1 경로. 다른 PC 면 127.0.0.1 을 그 PC IP 로.
#    - 패치가 check_embedding_ctx_length=False 를 주입해 "원문 텍스트"를 보낸다
#      (이게 없으면 langchain 이 tiktoken 토큰ID 정수배열을 보내 BGE 가 깨짐).
#    - ★ 동일 로컬 머신 직접 호출 → 프록시 미경유(안전). 패치가 이 host 를
#      NO_PROXY 에 자동 등록한다. HTTP(S)_PROXY 가 걸려 있어도 127.0.0.1 호출은
#      프록시로 새지 않는다(LLM 게이트웨이는 다른 host 라 영향 없음).
#    - 설정 후 검증:  python tools/launch.py check-embedding
# ───────────────────────────────────────────────────────────────
EMBEDDING=openai:bge-m3-korean
EMBEDDING_BASE_URL=http://127.0.0.1:8999/v1
EMBEDDING_API_KEY=***
# (선택) 수동으로도 명시 가능 — 패치가 자동 처리하므로 보통 불필요:
# NO_PROXY=127.0.0.1,localhost

# ───────────────────────────────────────────────────────────────
# 3) Tool-calling 우회 / MCP 비활성화
# ───────────────────────────────────────────────────────────────
MCP_STRATEGY=disabled
GPTR_DISABLE_TOOLCALLING=1

# ───────────────────────────────────────────────────────────────
# 3-b) 완전 오프라인 구동 (LLM·임베딩 API 호출만 예외)
#   gpt-researcher 는 런타임에 외부 리소스를 자동 다운로드하려 한다:
#     - tiktoken BPE 블록(비용산정 토크나이저) ← openaipublic.blob
#     - NLTK punkt/punkt_tab 등(.md/.docx 로더의 문장분할) ← nltk.org
#   에어갭/폐쇄망이면 이 다운로드가 실패한다.
#   → 'python tools/setup.py' 가 온라인 시점에 이 리소스를 offline/ 에 미리 받아두고,
#     패치가 TIKTOKEN_CACHE_DIR/NLTK_DATA 를 자동 연결해 네트워크 없이 로컬 파일만 읽는다.
#
#   GPTR_OFFLINE=1 : transformers/HF 라이브러리의 네트워크 접근까지 차단(안전망).
#                    오프라인 구동이 목표면 1 권장. tiktoken/nltk 캐시가 없으면 경고.
#   GPTR_AGENT_JSON_FALLBACK=1 : gpt-oss 가 JSON 을 안 지키고 빈/None 응답을 줄 때
#                    choose_agent 가 죽지 않고 기본 에이전트로 폴백(기본 ON).
#   (TIKTOKEN_CACHE_DIR / NLTK_DATA 는 패치가 offline/ 로 자동 설정 — 보통 직접 불필요)
GPTR_OFFLINE=1
GPTR_AGENT_JSON_FALLBACK=1

#   ★ tiktoken 이 SSL 로 막힌 경우(openaipublic.blob 접근 차단): BPE 블록을 수동 다운로드해
#   offline/tiktoken_cache/ 에 "sha1(URL)" 이름으로 두면 tiktoken 은 네트워크 없이 읽는다.
#     1) 다운로드 URL 확인:  python tools/launch.py tiktoken status   (각 인코딩 URL 출력)
#     2) 수동 설치       :  python tools/launch.py tiktoken install o200k_base.tiktoken cl100k_base.tiktoken
#        (또는 원본을 offline/manual/ 에 뛰 후 'python tools/setup.py' → 자동 편입)
#     3) SSL 미접속 검증 :  python tools/launch.py tiktoken verify
#   (선택) 캐시 위치·대상 인코딩·해시명을 직접 지정하려면:
# TIKTOKEN_CACHE_DIR=./offline/tiktoken_cache
# TIKTOKEN_ENCODINGS=o200k_base,cl100k_base
# TIKTOKEN_SHA1_O200K_BASE=fb374d419588a4632f3f557e76b4b70aebbca790
# TIKTOKEN_SHA1_CL100K_BASE=9b5ad71b2ce5302211f9c61530b329a4922fc6a4

# ───────────────────────────────────────────────────────────────
# 4) 검색(Retriever)
#    - duckduckgo: API 키 불요(무료, 기본값). tavily: 고품질이나 키 필요.
# ───────────────────────────────────────────────────────────────
RETRIEVER=duckduckgo
# RETRIEVER=tavily
# TAVILY_API_KEY=

# ───────────────────────────────────────────────────────────────
# 5) 데이터 소스 (web / local / hybrid)
#    - web    : 인터넷 검색(기본)
#    - local  : 내 로컬 문서만 사용(오프라인). 웹 미접속, BGE 임베딩 유사도만.
#    - hybrid : 로컬 문서 + 웹 검색
#    CLI 의 --source 가 이 값을 덮어쓴다. local/hybrid 는 BGE 서버 필수.
# ───────────────────────────────────────────────────────────────
REPORT_SOURCE=web

# 로컬 문서 디렉터리(REPORT_SOURCE=local/hybrid 일 때).
# tools/prepare_data.py 가 jsonl/csv/json 을 .txt(기본)/.md 로 변환해 여기에 채운다.
#   ★ 오프라인 권장: --format txt (기본). TextLoader 경로라 unstructured/NLTK 미경유.
#      --format md 는 UnstructuredMarkdownLoader → NLTK punkt_tab 필요(오프라인 시 setup 프로비저닝 필수).
# 미설정 시 기본값 data/docs 사용.
DOC_PATH=./data/docs

# ─────────────────────────────────────────
# 6) 실행 모드 / 출력 언어 / 레이트리미트
# ─────────────────────────────────────────
#   GPTR_RUN_MODE: rag | chrono  (CLI --mode 가 덮어씁)
#     - rag   : 유사도 기반 검색(기간 흐름 참고, 누락 허용). 임베딩 서버 필요.
#     - chrono: 전문서 map-reduce 요약(누락 0, 시간순) → 한글 비즈니스 보고서. 임베딩 불요(full-corpus).
GPTR_RUN_MODE=rag

#   출력 언어(vendor config 가 읽음). 기본 korean → 모든 보고서 프롬프트에 한국어 지시 주입.
LANGUAGE=korean
#   gpt-oss 가 언어를 흘릴 때 보강(기본: LANGUAGE 가 korean 이면 ON). 0 으로 비활성 가능.
# GPTR_FORCE_KOREAN=1

#   GPT-OSS 호출 cap(5회/sec) 대응 — 모든 LLM 호출을 이 초당 회수 이하로 스페이싱. 0 이하=비활성.
LLM_MAX_RPS=4

#   chrono 모드 배치 입력 한도(KB). 입력 컨텍스트 이 값 초과 금지 → 초과 예상 시 분할/재요약.
CHRONO_MAX_INPUT_KB=25

# ─────────────────────────────────────────
# 6-b) RAG 모드 튜닝 노브(선택) — 대용량 문서 커버리지 향상
# ─────────────────────────────────────────
#   SIMILARITY_THRESHOLD: 청크 채택 유사도 하한(vendor 기본 0.35). 낮출수록 더 많이 포함.
# SIMILARITY_THRESHOLD=0.25
#   GPTR_RAG_MAX_RESULTS: 하위질의당 상위 쳊d크 수(vendor 하드코딩 10 → 상향). 0=기본 유지.
# GPTR_RAG_MAX_RESULTS=20
#   청크 크기/중첩(full-corpus 시에도 적용).
# GPTR_CHUNK_SIZE=1000
# GPTR_CHUNK_OVERLAP=100
#   full-corpus(=chrono Stage2) 전량 포함. RAG 모드에서 수동 강제하려면 1.
# GPTR_LOCAL_FULL_CORPUS=0
#   full-corpus 청크 상한(0=무제한). 윈도우 초과 방지용 안전망.
# GPTR_LOCAL_MAX_CHUNKS=0

VERBOSE=true
REASONING_EFFORT=medium

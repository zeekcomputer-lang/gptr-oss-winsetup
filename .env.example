# ════════════════════════════════════════════════════════════════════════
#  GPT-Researcher × GPT-OSS — Windows 올인원 환경설정
#  복사: copy .env.example .env   (Windows)  /  cp .env.example .env
# ════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# 1) LLM (gpt-oss) — OpenAI 호환 엔드포인트
#    deep-doc-pipeline 패턴: base_url + default_headers(인증) + api_key 더미
# ───────────────────────────────────────────────────────────────
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=unused

# 모델 매핑 (gpt_researcher 형식: "<provider>:<model>")
# provider 는 openai 고정(=OpenAI 호환). model 은 서빙 중인 gpt-oss 이름.
FAST_LLM=openai:gpt-oss-20b
SMART_LLM=openai:gpt-oss-120b
STRATEGIC_LLM=openai:gpt-oss-120b

# LLM 전용 추가 인증 헤더 (JSON). 게이트웨이/프록시 인증이 필요할 때만.
#   - 이 헤더는 LLM 호출에만 주입됨. 임베딩(BGE)에는 절대 적용 안 됨.
# OPENAI_EXTRA_HEADERS={"Authorization":"Bearer xxxxx","X-Project-Id":"samsung"}

# 토큰 한도 (gpt-oss 출력 길이에 맞게 조정)
FAST_TOKEN_LIMIT=3000
SMART_TOKEN_LIMIT=8000
STRATEGIC_TOKEN_LIMIT=8000
TEMPERATURE=0.4

# ───────────────────────────────────────────────────────────────
# 2) 임베딩 (BGE) — 사용자가 별도로 운영하는 엔드포인트에 접속만 함
#    ※ 이 repo 는 임베딩 서버를 구동하지 않는다. 아래 URL 로 POST 호출만 한다.
#    - provider 는 openai 고정(=OpenAI 호환). model 은 서버가 응답하는 이름.
#    - EMBEDDING_BASE_URL 은 서버의 /v1 경로. 다른 PC 면 127.0.0.1 을 그 PC IP 로.
#    - 패치가 check_embedding_ctx_length=False 를 주입해 "원문 텍스트"를 보낸다
#      (이게 없으면 langchain 이 tiktoken 토큰ID 정수배열을 보내 BGE 가 깨짐).
#    - ★ 동일 로컬 머신 직접 호출 → 프록시 미경유(안전). 패치가 이 host 를
#      NO_PROXY 에 자동 등록한다. HTTP(S)_PROXY 가 걸려 있어도 127.0.0.1 호출은
#      프록시로 새지 않는다(LLM 게이트웨이는 다른 host 라 영향 없음).
#    - 설정 후 검증:  python tools/launch.py check-embedding
# ───────────────────────────────────────────────────────────────
EMBEDDING=openai:bge-m3-korean
EMBEDDING_BASE_URL=http://127.0.0.1:8999/v1
EMBEDDING_API_KEY=***
# (선택) 수동으로도 명시 가능 — 패치가 자동 처리하므로 보통 불필요:
# NO_PROXY=127.0.0.1,localhost

# ───────────────────────────────────────────────────────────────
# 3) Tool-calling 우회 / MCP 비활성화
# ───────────────────────────────────────────────────────────────
MCP_STRATEGY=disabled
GPTR_DISABLE_TOOLCALLING=1

# ───────────────────────────────────────────────────────────────
# 4) 검색(Retriever)
#    - duckduckgo: API 키 불요(무료, 기본값). tavily: 고품질이나 키 필요.
# ───────────────────────────────────────────────────────────────
RETRIEVER=duckduckgo
# RETRIEVER=tavily
# TAVILY_API_KEY=

# ───────────────────────────────────────────────────────────────
# 5) 데이터 소스 (web / local / hybrid)
#    - web    : 인터넷 검색(기본)
#    - local  : 내 로컬 문서만 사용(오프라인). 웹 미접속, BGE 임베딩 유사도만.
#    - hybrid : 로컬 문서 + 웹 검색
#    CLI 의 --source 가 이 값을 덮어쓴다. local/hybrid 는 BGE 서버 필수.
# ───────────────────────────────────────────────────────────────
REPORT_SOURCE=web

# 로컬 문서 디렉터리(REPORT_SOURCE=local/hybrid 일 때).
# tools/prepare_data.py 가 jsonl/csv/json 을 .md 로 변환해 여기에 채운다.
# 미설정 시 기본값 data/docs 사용.
DOC_PATH=./data/docs

VERBOSE=true
REASONING_EFFORT=medium
